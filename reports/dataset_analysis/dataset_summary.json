  "design_implications": [
    "All analyzed recordings use 256 Hz sampling, so resampling is not required initially.",
    "No single channel set appears in every recording; channel harmonization or per-channel missing handling is required.",
    "Median seizure duration is 45.5s, supporting short windows that can localize seizure transitions.",
    "Window-level labels are highly imbalanced; evaluation should report precision, recall, F1, sensitivity, specificity, and AUC rather than accuracy alone.",
    "Among tested settings, 5s windows with 50% overlap produced the least severe non-seizure/seizure ratio.",
    "Patient-wise splitting remains mandatory because windows from the same subject are strongly correlated.",
    "A 0.5-40 Hz bandpass is defensible for classical EEG seizure features because the candidate spectral bands stop at low gamma and high-frequency noise is reduced."
  ],
  "design_recommendations": {
    "rationale": {
      "bandpass": "0.5-40 Hz preserves delta through low-gamma features while reducing drift and high-frequency noise.",
      "channels": "A common-channel subset makes feature columns consistent for classical ML and patient-wise testing.",
      "labeling": "Any-overlap labeling captures seizure boundary windows and matches the clinical goal of detecting seizure presence.",
      "notch": "50 Hz notch is included because the requested pipeline targets 50 Hz line-noise suppression.",
      "sampling_frequency": "Use the dominant sampling frequency if all/most recordings match; otherwise keep frequency-aware feature extraction or resample.",
      "validation": "Patient-wise holdout avoids leakage from correlated windows belonging to the same subject.",
      "windowing": "Recommendation favors a candidate with manageable class imbalance while keeping windows short enough for seizure localization."
    },
    "recommended_values": {
      "bandpass_high_hz": 40.0,
      "bandpass_low_hz": 0.5,
      "channel_strategy": "harmonize_or_drop_inconsistent_channels",
      "labeling_strategy": "overlap_any_seizure_interval",
      "notch_frequency_hz": 50.0,
